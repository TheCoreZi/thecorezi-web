---
import FeedbackAdmin from '../../components/FeedbackAdmin';
import Layout from '../../layouts/Layout.astro';
import '../../styles/feedback-admin.css';

const isDev = import.meta.env.DEV;
const serviceKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY as string;
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL as string;
---

<Layout title="Admin - Feedback">
	{isDev && serviceKey ? (
		<FeedbackAdmin client:load serviceKey={serviceKey} supabaseUrl={supabaseUrl} />
	) : (
		<div style="text-align:center;padding:4rem;color:var(--color-text-muted);">
			<p>Panel no disponible.</p>
		</div>
	)}
</Layout>
