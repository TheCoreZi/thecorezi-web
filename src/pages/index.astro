---
import { Image } from 'astro:assets';
import ZoidCardList from '../components/ZoidCardList';
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';
import type { Zoid } from '../types/zoid';
import logo from '../assets/images/thecorezi.png';
import '../styles/zoid-card.css';

const INITIAL_COUNT = 3;

const { data: zoids } = await supabase
	.from('Zoids Releases')
	.select('*')
	.order('launch_date', { ascending: true, nullsFirst: false })
	.range(0, INITIAL_COUNT - 1);

const initialZoids = (zoids ?? []) as Zoid[];
---

<Layout title="Inicio">
	<section class="hero">
		<Image src={logo} alt="The Core Zi" class="hero-logo" height={200} loading="eager" />
		<p>Zoids corre por nuestras venas. Bienvenido al núcleo.</p>
	</section>

	<section id="lanzamientos">
		<h2 class="section-title">Próximos Lanzamientos</h2>
		{initialZoids.length === 0 ? (
			<p class="empty">No hay lanzamientos registrados aún.</p>
		) : (
			<ZoidCardList client:visible initialZoids={initialZoids} />
		)}
	</section>
</Layout>

<style>
	.hero {
		text-align: center;
		padding: 6rem 1rem 4rem;
	}

	.hero-logo {
		filter: invert(var(--logo-invert, 1));
		margin-bottom: 1.5rem;
		max-width: 100%;
		height: auto;
		transition: opacity 0.1s, transform 0.1s;
		will-change: opacity, transform;
	}

	.hero p {
		font-size: 1.25rem;
		color: var(--color-text-muted);
	}

	.section-title {
		font-size: 2rem;
		color: var(--color-accent);
		margin-bottom: 2rem;
	}

	.empty {
		color: var(--color-text-muted);
		font-size: 1.1rem;
	}

	@media (max-width: 550px) {
		.hero {
			padding: 3rem 1rem 2rem;
		}

		.hero-logo {
			height: auto;
			max-height: 120px;
		}

		.hero p {
			font-size: 1rem;
		}

		.section-title {
			font-size: 1.5rem;
			margin-bottom: 1.25rem;
		}
	}
</style>
