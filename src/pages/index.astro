---
import { Image } from 'astro:assets';
import { sellersByCountry } from '../data/sellers';
import ZoidCardList from '../components/ZoidCardList';
import Layout from '../layouts/Layout.astro';
import logo from '../assets/images/thecorezi.png';
import '../styles/zoid-card.css';
---

<Layout title="Inicio">
	<section class="hero">
		<Image src={logo} alt="The Core Zi" class="hero-logo" height={200} loading="eager" />
		<p>Zoids corre por nuestras venas. Bienvenido al núcleo.</p>
	</section>

	<section id="lanzamientos">
		<h2 class="section-title">Próximos Lanzamientos</h2>
		<ZoidCardList client:visible />
	</section>

	<section id="donde-comprar">
		<h2 class="section-title">¿Dónde comprar?</h2>
		<p class="section-description">Encontrar dónde comprar Zoids no es fácil. No es una franquicia que encuentres en cualquier estante, así que la mayoría de vendedores son independientes que se mueven en redes sociales y grupos. Armamos esta lista con vendedores y comunidades donde hemos comprado personalmente. No estamos afiliados a ninguno y, siendo honestos, la mayoría nos cae mal. Aun así, esperamos que esta lista les ayude a conseguir el Zoid que tanto buscan.</p>
		<div class="country-flags">
			{sellersByCountry.map((group, i) => (
				<button class="country-flag" data-country-index={i}>
					{group.country}
				</button>
			))}
		</div>
		{sellersByCountry.map((group, i) => (
			<div class="country-group" data-country-group={i} hidden>
				{group.sellers.map((seller) => (
					<div class="seller-card">
						{seller.image && (
							<img src={seller.image} alt={seller.name} class="seller-image" width="160" />
						)}
						<div class="seller-header">
							<h4 class="seller-name">{seller.name}</h4>
							<a href={seller.link} target="_blank" rel="noopener noreferrer" class="seller-link">
								Visitar ↗
							</a>
						</div>
						<p class="seller-description">{seller.description}</p>
						<div class="seller-details">
							<div class="seller-pros">
								<h5>Lo bueno</h5>
								<ul>
									{seller.pros.map((pro) => (
										<li>{pro}</li>
									))}
								</ul>
							</div>
							<div class="seller-cons">
								<h5>Lo malo</h5>
								<ul>
									{seller.cons.map((con) => (
										<li>{con}</li>
									))}
								</ul>
							</div>
						</div>
					</div>
				))}
			</div>
		))}
	</section>

	<script>
		document.querySelectorAll('.country-flag').forEach((btn) => {
			btn.addEventListener('click', () => {
				const index = (btn as HTMLElement).dataset.countryIndex;
				const group = document.querySelector(`[data-country-group="${index}"]`);
				const isVisible = !group?.hasAttribute('hidden');

				document.querySelectorAll('.country-group').forEach((g) => g.setAttribute('hidden', ''));
				document.querySelectorAll('.country-flag').forEach((b) => b.classList.remove('active'));

				if (!isVisible) {
					group?.removeAttribute('hidden');
					btn.classList.add('active');
				}
			});
		});
	</script>
</Layout>

<style>
	.hero {
		text-align: center;
		padding: 6rem 1rem 4rem;
	}

	.hero-logo {
		filter: invert(var(--logo-invert, 1));
		margin-bottom: 1.5rem;
		max-width: 100%;
		height: auto;
		transition: opacity 0.1s, transform 0.1s;
		will-change: opacity, transform;
	}

	.hero p {
		font-size: 1.25rem;
		color: var(--color-text-muted);
	}

	.section-title {
		font-size: 2rem;
		color: var(--color-accent);
		margin-bottom: 2rem;
	}

	.empty {
		color: var(--color-text-muted);
		font-size: 1.1rem;
	}

	#donde-comprar {
		margin-top: 4rem;
	}

	.section-description {
		color: var(--color-text-muted);
		font-size: 1rem;
		line-height: 1.6;
		margin-bottom: 2rem;
	}

	.country-flags {
		display: flex;
		gap: 1rem;
		justify-content: center;
		margin-bottom: 2rem;
	}

	.country-flag {
		font-size: 3rem;
		background: none;
		border: 2px solid transparent;
		border-radius: 12px;
		padding: 0.5rem 1rem;
		cursor: pointer;
		transition: border-color 0.2s, transform 0.2s;
	}

	.country-flag:hover {
		transform: scale(1.15);
	}

	.country-flag.active {
		border-color: var(--color-accent);
		transform: scale(1.15);
	}

	.country-group {
		margin-bottom: 2rem;
	}

	.seller-card {
		background-color: var(--color-surface);
		border-radius: 12px;
		padding: 1.5rem;
		margin-bottom: 1rem;
		overflow: hidden;
	}

	.seller-image {
		float: left;
		width: 160px;
		height: auto;
		border-radius: 8px;
		margin: 0 1rem 0.75rem 0;
		object-fit: cover;
	}

	.seller-header {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.seller-name {
		color: var(--color-accent);
		font-size: 1.5rem;
	}

	.seller-link {
		display: inline-block;
		color: var(--color-primary);
		background-color: rgba(255, 255, 255, 0.05);
		border: 1px solid var(--color-primary);
		border-radius: 6px;
		padding: 0.3rem 0.75rem;
		font-size: 0.85rem;
		font-weight: 600;
		text-decoration: none;
		margin: 0;
		transition: background-color 0.2s, color 0.2s;
	}

	.seller-link:hover {
		background-color: var(--color-primary);
		color: var(--color-text);
	}

	.seller-description {
		color: var(--color-text-muted);
		margin: 0.75rem 0 1rem;
		line-height: 1.5;
	}

	.seller-details {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}

	.seller-details h5 {
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.5rem;
	}

	.seller-pros h5 {
		color: var(--color-positive);
	}

	.seller-cons h5 {
		color: var(--color-negative);
	}

	.seller-details ul {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.seller-pros li::before {
		content: '✓ ';
		color: var(--color-positive);
		font-weight: 700;
	}

	.seller-cons li::before {
		content: '✗ ';
		color: var(--color-negative);
		font-weight: 700;
	}

	.seller-details li {
		font-size: 0.9rem;
		color: var(--color-text);
		line-height: 1.4;
	}

	@media (max-width: 550px) {
		.hero {
			padding: 3rem 1rem 2rem;
		}

		.hero-logo {
			height: auto;
			max-height: 120px;
		}

		.hero p {
			font-size: 1rem;
		}

		.section-title {
			font-size: 1.5rem;
			margin-bottom: 1.25rem;
		}

		#donde-comprar {
			margin-top: 2rem;
		}

		.seller-details {
			grid-template-columns: 1fr;
			gap: 1rem;
		}

		.seller-card {
			padding: 1rem;
		}
	}
</style>
