---
import NewsList from '../../components/NewsList';
import Layout from '../../layouts/Layout.astro';
import '../../styles/news.css';
---

<Layout title="Noticias de Zoids" description="Las últimas noticias del mundo Zoids: anuncios, colaboraciones y novedades de la franquicia.">
	<h1 class="news-page-title">Noticias</h1>
	<NewsList client:load />
</Layout>

<style>
	.news-page-title {
		color: var(--color-accent);
		font-family: 'Russo One', sans-serif;
		font-size: 2.5rem;
		margin-bottom: 2rem;
		position: relative;
		padding-bottom: 1rem;
		text-align: center;
	}

	.news-page-title::after {
		background: linear-gradient(90deg, transparent, var(--color-accent), transparent);
		border-radius: 2px;
		bottom: 0;
		content: '';
		height: 3px;
		left: 50%;
		position: absolute;
		transform: translateX(-50%);
		width: 80px;
	}

	@media (max-width: 550px) {
		.news-page-title {
			font-size: 1.75rem;
		}
	}
</style>
