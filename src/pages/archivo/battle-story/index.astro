---
import Layout from '../../../layouts/Layout.astro';
import { sources, timelineByEra } from '../../../data/timeline';
import arrowDownFill from '../../../assets/icons/arrow-down-fill.svg';
import chevronRight from '../../../assets/icons/chevron-right.svg';
import iconBook from '../../../assets/icons/source-book.svg';
import iconBox from '../../../assets/icons/source-box.svg';
import iconMagazine from '../../../assets/icons/source-magazine.svg';
import iconWeb from '../../../assets/icons/source-web.svg';

const iconMap = { book: iconBook, box: iconBox, magazine: iconMagazine, web: iconWeb } as const;
---

<Layout title="Battle Story" description="Conoce el Battle Story de Zoids: la narrativa que conecta los model kits con décadas de guerras en el Planeta Zi.">
	<a href="/archivo/" class="back-btn">← Volver al Archivo</a>

	<section class="bs-hero">
		<h1 class="bs-title">Battle Story</h1>
		<p class="bs-subtitle">La historia detrás de los model kits</p>
	</section>

	<section class="bs-intro">
		<p>El <strong>Battle Story</strong> es la narrativa oficial que acompaña a los modelos de Zoids desde 1983. A diferencia de los animes, que cuentan historias independientes, la Battle Story es una saga continua que conecta cada kit lanzado por TOMY con las guerras en el Planeta Zi.</p>
		<p>La historia se contaba a través de las cajas de los Zoids, manuales de instrucciones, libros complementarios como los <em>Zoids Battle Story</em> de Shogakukan, revistas como <em>Dengeki Hobby</em>, y publicaciones oficiales como los <em>Fan Books</em>. Cada nuevo Zoid lanzado al mercado tenía un papel en la narrativa: su origen, su primer despliegue en batalla y su impacto en la guerra.</p>
		<p>La Battle Story abarca miles de años de historia, desde la formación del Planeta Zi y la evolución de las primeras formas de vida metálicas, pasando por las guerras entre la <strong>República de Helic</strong> y el <strong>Imperio de Zenebas</strong>, la intervención del <strong>Imperio de Guylos</strong>, la devastadora <strong>Gran Catástrofe</strong>, hasta el surgimiento del <strong>Imperio de Neo Zenebas</strong> y las batallas del futuro lejano.</p>
		<p>Es una historia de guerra, política, traición y tecnología — contada modelo a modelo durante décadas y que aún sigue en desarrollo.</p>
	</section>

	<section class="timeline-section">
		<h2 class="timeline-heading">Línea del Tiempo</h2>
		<p class="timeline-note">Todas las fechas están en el calendario de Planet Zi, "ZAC" (Zi Anno Civitas).</p>

		<div id="era-selector">
			<div class="era-selector-timeline">
				{timelineByEra.map((era, i) => (
					<button class={`era-selector-node ${i % 2 === 0 ? 'era-selector-node--left' : 'era-selector-node--right'}`} data-era-select={i} data-era-key={era.era} style={`--era-color: ${era.color}; --pulse-delay: ${(Math.random() * 2).toFixed(2)}s`} type="button">
						<span class="era-selector-dot"></span>
						<div class="era-selector-info">
							<span class="era-selector-label">{era.label}</span>
							<span class="era-selector-range">{era.yearRange}</span>
						</div>
					</button>
				))}
			</div>
		</div>

		<div id="era-detail" hidden>
			<nav class="era-nav">
				{timelineByEra.map((era) => (
					<a href={`#era-${era.era}`} class="era-nav-item" style={`--era-color: ${era.color}`}>
						<span class="era-nav-dot"></span>
						<span class="era-nav-label">{era.label} <span class="era-nav-range">({era.yearRange})</span></span>
					</a>
				))}
			</nav>

		{timelineByEra.map((era, eraIndex) => (
			<div class="era-page" data-era-page={eraIndex} hidden={eraIndex !== 0}>
				<div class="era-separator" style={`--era-color: ${era.color}`}>
					<div class="era-separator-line"></div>
					<div class="era-separator-content">
						<h3 class="era-separator-title">{era.label}</h3>
						<span class="era-separator-range">{era.yearRange}</span>
					</div>
					<div class="era-separator-line"></div>
				</div>

				{eraIndex > 0 && (
					<div class="era-nav-buttons">
						<button class="era-arrow era-arrow--prev" data-direction="prev" data-era-index={eraIndex} type="button" style={`--next-era-color: ${timelineByEra[eraIndex - 1].color}`}>
							<span class="era-arrow-tip era-arrow-tip--up" style={`-webkit-mask-image: url(${arrowDownFill.src}); mask-image: url(${arrowDownFill.src})`}></span>
							<span class="era-arrow-label">{timelineByEra[eraIndex - 1].label}</span>
						</button>
					</div>
				)}

				<button class="era-back-btn" data-era-back type="button">← Eras</button>
				<div class="timeline" style={`--era-color: ${era.color}`}>
					{era.events.map((event, i) => (
						<div class={`timeline-item ${i % 2 === 0 ? 'timeline-item--left' : 'timeline-item--right'}`}>
							<div class="timeline-dot" style={`--pulse-delay: ${(Math.random() * 2).toFixed(2)}s`}></div>
							<div class="timeline-content" data-collapsible>
								<div class="timeline-header">
									<span class="timeline-date">{event.date}</span>
									<h4 class="timeline-event-title">{event.title}</h4>
									<span class="timeline-chevron" style={`-webkit-mask-image: url(${chevronRight.src}); mask-image: url(${chevronRight.src})`}></span>
								</div>
								<div class="timeline-details">
									<div class="timeline-details-inner">
										<p class="timeline-event-desc">{event.description}</p>
										{event.newZoids && event.newZoids.length > 0 && (
											<div class="timeline-zoids">
												<span class="timeline-zoids-label">Zoids destacados:</span>
												{event.newZoids.map((z) => (
													<span class="timeline-zoid-tag">{z}</span>
												))}
											</div>
										)}
									</div>
								</div>
							</div>
						</div>
					))}
				</div>

				{eraIndex < timelineByEra.length - 1 && (
					<div class="era-nav-buttons">
						<button class="era-arrow" data-direction="next" data-era-index={eraIndex} type="button" style={`--next-era-color: ${timelineByEra[eraIndex + 1].color}`}>
							<span class="era-arrow-tip" style={`-webkit-mask-image: url(${arrowDownFill.src}); mask-image: url(${arrowDownFill.src})`}></span>
							<span class="era-arrow-label">{timelineByEra[eraIndex + 1].label}</span>
						</button>
					</div>
				)}
			</div>
		))}
		</div>
	</section>

	<section class="credits">
		<h2 class="credits-title">Créditos</h2>
		<p class="credits-text">Esta línea del tiempo está basada en el trabajo de <strong>Falcarius</strong>, publicada originalmente en <a href="http://zoidsathenaeum.890m.com/databanks/timeline.htm" target="_blank" rel="noopener noreferrer">Zoids Athenaeum</a>. Traducida y adaptada al español por The Core Zi.</p>

		<details class="sources-details">
			<summary class="sources-summary">Ver fuentes originales</summary>
			<ul class="sources-list">
				{sources.map((s) => (
					<li><span class="source-icon" style={`-webkit-mask-image: url(${iconMap[s.icon].src}); mask-image: url(${iconMap[s.icon].src})`}></span>{s.url ? <a href={s.url} target="_blank" rel="noopener noreferrer">{s.description}</a> : s.description}</li>
				))}
			</ul>
		</details>
	</section>
</Layout>

<script>
	document.addEventListener('astro:page-load', () => {
		const eraSelector = document.getElementById('era-selector');
		const eraDetail = document.getElementById('era-detail');
		if (!eraSelector || !eraDetail) return;

		const eraBackBtns = document.querySelectorAll('[data-era-back]');
		const eraPages = document.querySelectorAll('.era-page');
		const eraNavItems = document.querySelectorAll('.era-nav-item');

		const eraKeys = Array.from(document.querySelectorAll('[data-era-key]')).map(
			(node) => (node as HTMLElement).dataset.eraKey!,
		);

		function showSelector() {
			eraDetail.hidden = true;
			eraSelector.hidden = false;
			history.replaceState(null, '', window.location.pathname);
			document.querySelector('.timeline-section')?.scrollIntoView({ behavior: 'smooth' });
		}

		function showEra(index: number, scroll = true) {
			document.querySelectorAll('.timeline-content--open').forEach((c) => c.classList.remove('timeline-content--open'));
			eraSelector.hidden = true;
			eraDetail.hidden = false;
			eraPages.forEach((g, i) => {
				(g as HTMLElement).hidden = i !== index;
			});
			eraNavItems.forEach((item, i) => {
				item.classList.toggle('era-nav-item--active', i === index);
			});
			history.replaceState(null, '', `#${eraKeys[index]}`);
			if (scroll) {
				document.querySelector('.timeline-section')?.scrollIntoView({ behavior: 'smooth' });
			}
		}

		document.querySelectorAll('.era-selector-node').forEach((node) => {
			node.addEventListener('click', () => {
				showEra(Number((node as HTMLElement).dataset.eraSelect));
			});
		});

		eraBackBtns.forEach((btn) => btn.addEventListener('click', showSelector));

		eraNavItems.forEach((item, i) => {
			item.addEventListener('click', (e) => {
				e.preventDefault();
				showEra(i);
			});
		});

		document.querySelectorAll('.era-arrow').forEach((btn) => {
			btn.addEventListener('click', () => {
				const currentIndex = Number((btn as HTMLElement).dataset.eraIndex);
				const direction = (btn as HTMLElement).dataset.direction;
				showEra(direction === 'next' ? currentIndex + 1 : currentIndex - 1);
			});
		});

		document.querySelectorAll('.timeline-content[data-collapsible]').forEach((card) => {
			card.addEventListener('click', () => {
				const isOpen = card.classList.contains('timeline-content--open');
				document.querySelectorAll('.timeline-content--open').forEach((c) => c.classList.remove('timeline-content--open'));
				if (!isOpen) {
					card.classList.add('timeline-content--open');
				}
			});
		});

		const hash = window.location.hash.slice(1);
		if (hash) {
			const eraIndex = eraKeys.indexOf(hash);
			if (eraIndex !== -1) {
				showEra(eraIndex, false);
			}
		}
	});
</script>

<style is:global>
	.back-btn {
		display: inline-block;
		background: var(--color-surface);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 8px;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
		color: var(--color-text);
		font-family: 'Russo One', sans-serif;
		font-size: 0.85rem;
		padding: 0.5rem 1rem;
		text-decoration: none;
		transition: background-color 0.2s, border-color 0.2s, color 0.2s;
	}

	.back-btn:hover {
		background: var(--color-accent);
		border-color: var(--color-accent);
		color: var(--color-bg);
	}

	/* Hero */
	.bs-hero {
		text-align: center;
		padding: 3rem 1rem 1rem;
	}

	.bs-title {
		font-family: 'Russo One', sans-serif;
		font-size: 3rem;
		color: var(--color-accent);
		margin-bottom: 0.25rem;
	}

	.bs-subtitle {
		font-family: 'Russo One', sans-serif;
		font-size: 1.1rem;
		color: var(--color-text-muted);
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	/* Intro */
	.bs-intro {
		max-width: 750px;
		margin: 2rem auto 0;
	}

	.bs-intro p {
		color: var(--color-text-muted);
		font-size: 1rem;
		line-height: 1.7;
		margin-bottom: 1rem;
	}

	.bs-intro strong {
		color: var(--color-text);
	}

	.bs-intro em {
		color: var(--color-accent);
		font-style: italic;
	}

	/* Timeline section */
	.timeline-section {
		margin-top: 4rem;
	}

	.timeline-heading {
		font-family: 'Russo One', sans-serif;
		font-size: 2rem;
		color: var(--color-accent);
		text-align: center;
		margin-bottom: 0.5rem;
		position: relative;
		padding-bottom: 0.75rem;
	}

	.timeline-heading::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 50%;
		transform: translateX(-50%);
		width: 80px;
		height: 3px;
		background: linear-gradient(90deg, transparent, var(--color-accent), transparent);
		border-radius: 2px;
	}

	.timeline-note {
		color: var(--color-text-muted);
		font-size: 0.85rem;
		font-style: italic;
		opacity: 0.7;
		text-align: center;
		margin-bottom: 2rem;
	}

	/* Era selector */
	.era-selector-timeline {
		position: relative;
		max-width: 700px;
		margin: 0 auto;
		padding: 2rem 0;
	}

	.era-selector-timeline::before {
		content: '';
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		top: 0;
		bottom: 0;
		width: 2px;
		background: var(--color-text-muted);
		opacity: 0.2;
	}

	.era-selector-node {
		background: none;
		border: none;
		cursor: pointer;
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 1.25rem 0;
		position: relative;
		width: 100%;
		transition: transform 0.2s;
	}

	.era-selector-node:hover {
		transform: scale(1.03);
	}

	.era-selector-node:hover .era-selector-label {
		color: var(--era-color);
	}

	.era-selector-node--left {
		flex-direction: row-reverse;
		text-align: right;
	}

	.era-selector-node--right {
		text-align: left;
	}

	.era-selector-dot {
		background: var(--era-color);
		border: 2px solid var(--color-bg);
		border-radius: 50%;
		flex-shrink: 0;
		height: 16px;
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		width: 16px;
		z-index: 2;
	}

	.era-selector-dot::after {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 100%;
		height: 100%;
		border-radius: 50%;
		border: 2px solid var(--era-color);
		animation: radar-pulse 2s ease-out infinite;
		animation-delay: var(--pulse-delay, 0s);
	}

	.era-selector-info {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.era-selector-node--left .era-selector-info {
		margin-right: calc(50% + 1.5rem);
		align-items: flex-end;
	}

	.era-selector-node--right .era-selector-info {
		margin-left: calc(50% + 1.5rem);
		align-items: flex-start;
	}

	.era-selector-label {
		color: var(--color-text);
		font-family: 'Russo One', sans-serif;
		font-size: 1rem;
		transition: color 0.2s;
	}

	.era-selector-range {
		color: var(--color-text-muted);
		font-size: 0.75rem;
	}

	/* Era back button */
	.era-page {
		position: relative;
	}

	.era-back-btn {
		background: var(--color-surface);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 8px;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
		color: var(--color-text);
		cursor: pointer;
		font-family: 'Russo One', sans-serif;
		font-size: 0.75rem;
		left: 0rem;
		padding: 0.4rem 0.75rem;
		position: absolute;
		top: 4rem;
		transition: background-color 0.2s, border-color 0.2s, color 0.2s;
		z-index: 10;
	}

	.era-back-btn:hover {
		background: var(--color-accent);
		border-color: var(--color-accent);
		color: var(--color-bg);
	}

	/* Era navigation */
	.era-nav {
		display: flex;
		justify-content: center;
		gap: 1.5rem;
		margin-bottom: 3rem;
		flex-wrap: wrap;
	}

	.era-nav-item {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		color: var(--color-text-muted);
		font-size: 0.85rem;
		transition: color 0.2s;
	}

	.era-nav-item:hover {
		color: var(--color-text);
	}

	.era-nav-item--active {
		color: var(--color-text);
	}

	.era-nav-item--active .era-nav-dot {
		box-shadow: 0 0 8px var(--era-color);
		transform: scale(1.3);
	}

	.era-nav-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--era-color);
		flex-shrink: 0;
	}

	.era-nav-range {
		opacity: 0.6;
		font-size: 0.75rem;
	}

	/* Timeline */
	.timeline {
		position: relative;
		max-width: 900px;
		margin: 0 auto;
		padding: 0 1rem;
	}

	.timeline::before {
		content: '';
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		top: 0;
		bottom: 0;
		width: 2px;
		background: var(--color-text-muted);
		opacity: 0.2;
	}

	/* Era separator */
	.era-separator {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		margin: 3rem 0 2rem;
		position: relative;
		z-index: 1;
		scroll-margin-top: 100px;
	}

	.era-separator:first-child {
		margin-top: 0;
	}

	.era-separator-line {
		flex: 1;
		height: 2px;
		background: linear-gradient(90deg, transparent, var(--era-color), transparent);
	}

	.era-separator-content {
		text-align: center;
		flex-shrink: 0;
	}

	.era-separator-title {
		font-family: 'Russo One', sans-serif;
		font-size: 1.25rem;
		color: var(--era-color);
		margin-bottom: 0.15rem;
	}

	.era-separator-range {
		font-size: 0.8rem;
		color: var(--color-text-muted);
	}

	/* Timeline items */
	.timeline-item {
		position: relative;
		width: 50%;
		padding: 0 2.5rem 2rem;
	}

	.timeline-item--left {
		left: 0;
		padding-right: 2.5rem;
		text-align: right;
	}

	.timeline-item--right {
		left: 50%;
		padding-left: 2.5rem;
		text-align: left;
	}

	.timeline-dot {
		position: absolute;
		top: 0.5rem;
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: var(--era-color);
		border: 2px solid var(--color-bg);
		z-index: 2;
	}

	.timeline-dot::after {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 100%;
		height: 100%;
		border-radius: 50%;
		border: 2px solid var(--era-color);
		animation: radar-pulse 2s ease-out infinite;
		animation-delay: var(--pulse-delay, 0s);
	}

	@keyframes radar-pulse {
		0% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; }
		100% { transform: translate(-50%, -50%) scale(3); opacity: 0; }
	}

	.timeline-item--left .timeline-dot {
		right: -6px;
	}

	.timeline-item--right .timeline-dot {
		left: -6px;
	}

	.timeline-content {
		background: color-mix(in srgb, var(--color-bg) 99%, transparent);
		border: 1px solid transparent;
		border-radius: 12px;
		cursor: pointer;
		padding: 0.75rem;
		transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
	}

	.timeline-content:hover .timeline-date,
	.timeline-content:hover .timeline-event-title {
		transform: scale(1.03);
	}

	.timeline-content:hover .timeline-date {
		box-shadow: 0 0 8px color-mix(in srgb, var(--era-color) 40%, transparent);
	}

	.timeline-content--open {
		background: var(--color-surface);
		border-color: var(--era-color);
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
	}

	.timeline-header {
		display: grid;
		grid-template-columns: 1fr auto;
		grid-template-rows: auto auto;
		gap: 0.25rem;
	}

	.timeline-chevron {
		background-color: var(--color-accent);
		display: inline-block;
		grid-column: 2;
		grid-row: 1 / -1;
		align-self: center;
		height: 14px;
		mask-repeat: no-repeat;
		mask-size: contain;
		opacity: 0;
		transition: transform 0.2s, opacity 0.2s;
		width: 14px;
		-webkit-mask-repeat: no-repeat;
		-webkit-mask-size: contain;
	}

	.timeline-content--open .timeline-chevron {
		opacity: 1;
	}

	.timeline-item--left .timeline-header {
		grid-template-columns: auto 1fr;
	}

	.timeline-item--left .timeline-date {
		grid-column: 2;
		justify-self: end;
	}

	.timeline-item--left .timeline-event-title {
		grid-column: 2;
		text-align: right;
	}

	.timeline-item--left .timeline-chevron {
		grid-column: 1;
		transform: rotate(180deg);
	}

	.timeline-content--open .timeline-chevron {
		transform: rotate(90deg);
	}

	.timeline-item--left .timeline-content--open .timeline-chevron {
		transform: rotate(90deg);
	}

	.timeline-details {
		display: grid;
		grid-template-rows: 0fr;
		opacity: 0;
		transition: grid-template-rows 0.3s ease, opacity 0.3s ease;
	}

	.timeline-details-inner {
		overflow: hidden;
	}

	.timeline-content--open .timeline-details {
		grid-template-rows: 1fr;
		opacity: 1;
	}

	.timeline-content--open .timeline-details-inner {
		padding-top: 0.75rem;
	}

	.timeline-date {
		background: var(--era-color);
		color: #000;
		font-family: 'Russo One', sans-serif;
		font-size: 0.7rem;
		padding: 0.2rem 0.6rem;
		border-radius: 4px;
		letter-spacing: 0.03em;
