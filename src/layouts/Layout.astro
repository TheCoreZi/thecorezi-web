---
import { Image } from 'astro:assets';
import logo from '../assets/images/thecorezi.png';
import CurrencySelector from '../components/CurrencySelector.astro';
import ThemeSelector from '../components/ThemeSelector.astro';

interface Props {
	description?: string;
	image?: string;
	title: string;
}

const defaultDescription = 'Zoids corre por nuestras venas. Bienvenido al núcleo. Somos una comunidad de fans de Zoids en español — si creías que estabas solo, ya no más.';
const {
	description = defaultDescription,
	image = '/og-image.png',
	title,
} = Astro.props;
const fullTitle = `${title} | The Core Zi`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/favicon.ico" sizes="48x48" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#0b1a2e" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Russo+One&display=swap" rel="stylesheet" />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.site)} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="The Core Zi" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL(image, Astro.site)} />

		<title>{fullTitle}</title>
	</head>
	<body>
		<nav class="navbar" id="navbar">
			<ul class="navbar-links">
				<li><a href="#lanzamientos">Lanzamientos</a></li>
				<li><a href="#donde-comprar">¿Dónde comprar?</a></li>
			</ul>
			<a href="/" class="navbar-brand" id="navbar-brand">
				<Image src={logo} alt="The Core Zi" height={48} loading="eager" />
			</a>
			<ul class="navbar-links">
				<li><a href="#podcast">Podcast</a></li>
				<li><a href="#zoids-sleeper">Zoids Sleeper</a></li>
			</ul>
		</nav>
		<main>
			<slot />
		</main>

		<script>
			const navbar = document.getElementById('navbar')!;
			const navbarBrand = document.getElementById('navbar-brand')!;
			const heroLogo = document.querySelector('.hero-logo') as HTMLImageElement | null;

			if (heroLogo) {
				const scrollThreshold = 200;

				function updateLogoOnScroll() {
					const scrollY = window.scrollY;
					const progress = Math.min(scrollY / scrollThreshold, 1);

					heroLogo!.style.opacity = String(1 - progress);
					heroLogo!.style.transform = `scale(${1 - progress * 0.5})`;

					navbarBrand.style.opacity = String(progress);
					navbarBrand.style.pointerEvents = progress > 0.5 ? 'auto' : 'none';

					if (progress > 0) {
						navbar.classList.add('navbar--scrolled');
					} else {
						navbar.classList.remove('navbar--scrolled');
					}
				}

				navbarBrand.style.opacity = '0';
				navbarBrand.style.pointerEvents = 'none';

				window.addEventListener('scroll', updateLogoOnScroll, { passive: true });
				updateLogoOnScroll();
			}
		</script>
		<footer>
			<div class="footer-social">
				<a href="https://www.facebook.com/TheCoreZi" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
					<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
				</a>
				<a href="https://www.youtube.com/@thecorezi8773" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
					<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
				</a>
				<a href="https://open.spotify.com/show/033kHuneLO4Chrsaq53l1y" target="_blank" rel="noopener noreferrer" aria-label="Spotify">
					<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
				</a>
				<a href="https://buymeacoffee.com/thecorezi" target="_blank" rel="noopener noreferrer" aria-label="Buy Me a Coffee">
					<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M20.216 6.415l-.132-.666c-.119-.598-.388-1.163-1.001-1.379-.197-.069-.42-.098-.57-.241-.152-.143-.196-.366-.231-.572-.065-.378-.125-.756-.192-1.133-.057-.325-.102-.69-.25-.987-.195-.4-.597-.634-.996-.788a5.723 5.723 0 00-.626-.194c-1-.263-2.05-.36-3.077-.416a25.834 25.834 0 00-3.7.062c-.915.083-1.88.184-2.75.5-.318.116-.646.256-.888.501-.297.302-.393.77-.177 1.146.154.267.415.456.692.58.36.162.737.284 1.123.366 1.075.238 2.189.331 3.287.37 1.218.05 2.437.01 3.65-.118.299-.033.598-.073.896-.119.352-.054.578-.513.474-.834-.124-.383-.457-.531-.834-.473-.466.074-.96.108-1.382.146-1.177.08-2.358.082-3.536.006a22.228 22.228 0 01-1.157-.107c-.086-.01-.18-.025-.258-.036-.243-.036-.484-.08-.724-.13-.111-.027-.111-.185 0-.212h.005c.277-.06.557-.108.838-.147h.002c.131-.009.263-.032.394-.048a25.076 25.076 0 013.426-.12c.674.019 1.347.067 2.017.144l.228.031c.267.04.533.088.798.145.392.085.895.113 1.07.542.055.137.08.288.111.431l.319 1.484a.237.237 0 01-.199.284h-.003c-.037.006-.075.01-.112.015a36.704 36.704 0 01-4.743.295 37.059 37.059 0 01-4.699-.304c-.14-.017-.293-.042-.417-.06-.326-.048-.649-.108-.973-.161-.393-.065-.768-.032-1.123.161-.29.16-.527.404-.675.701-.154.316-.199.66-.267 1-.069.34-.176.707-.135 1.056.087.753.613 1.365 1.37 1.502a39.69 39.69 0 0011.343.376.483.483 0 01.535.53l-.071.697-1.018 9.907c-.041.41-.047.832-.125 1.237-.122.637-.553 1.028-1.182 1.171-.577.131-1.165.2-1.756.205-.656.004-1.305-.061-1.95-.19-.534-.107-.884-.525-.997-1.063-.09-.432-.1-.876-.14-1.313l-.816-7.94a.26.26 0 00-.26-.24.26.26 0 00-.26.26v.01l.854 8.318c.058.482.126.965.238 1.436.2.827.786 1.348 1.596 1.543.755.182 1.529.264 2.303.238.775-.022 1.543-.122 2.28-.374.82-.279 1.28-.9 1.388-1.757.048-.396.063-.796.098-1.194l.985-9.587.018-.167a.088.088 0 01.076-.075c.086-.012.168-.036.249-.06.203-.061.403-.133.6-.21a4.068 4.068 0 001.921-1.598c.399-.7.58-1.487.62-2.302.033-.678-.07-1.37-.396-1.987z"/></svg>
				</a>
			</div>
			<div class="footer-controls">
				<CurrencySelector />
				<ThemeSelector />
			</div>
			<p>&copy; {new Date().getFullYear()} The Core Zi</p>
		</footer>
	</body>
</html>

<style>
	:global(:root) {
		--color-bg: #0b1a2e;
		--color-surface: #112240;
		--color-primary: #1a6bb5;
		--color-accent: #e8a020;
		--color-highlight: #3d8c40;
		--color-negative: #c0392b;
		--color-positive: #27ae60;
		--color-text: #e0e8f0;
		--color-text-muted: #7a9bbf;
	}

	:global(*) {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	:global(html) {
		scroll-behavior: smooth;
	}

	:global(body) {
		font-family: 'Rajdhani', system-ui, -apple-system, sans-serif;
		font-weight: 500;
		background-color: var(--color-bg);
		color: var(--color-text);
		min-height: 100vh;
	}

	.navbar {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		padding: 1.5rem 2rem;
		background-color: transparent;
		position: sticky;
		top: 0;
		z-index: 100;
		transition: background-color 0.3s, padding 0.3s;
	}

	.navbar--scrolled {
		background-color: var(--color-bg);
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
		padding: 0.75rem 2rem;
	}

	.navbar-brand {
		margin: 0 2rem;
		line-height: 0;
		transition: opacity 0.3s;
		justify-self: center;
	}

	.navbar-brand img {
		filter: invert(var(--logo-invert, 1));
	}

	.navbar-links {
		display: flex;
		list-style: none;
		gap: 1.5rem;
	}

	.navbar-links:first-child {
		justify-content: flex-end;
	}

	.navbar-links:last-child {
		justify-content: flex-start;
	}

	.navbar-links a {
		color: var(--color-text);
		text-decoration: none;
		text-transform: uppercase;
		font-family: 'Russo One', sans-serif;
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.05em;
		transition: color 0.2s;
	}

	.navbar-links a:hover {
		color: var(--color-accent);
	}

	main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem;
	}

	footer {
		text-align: center;
		padding: 2rem;
		color: var(--color-text-muted);
		border-top: 1px solid var(--color-surface);
		margin-top: 4rem;
	}

	.footer-social {
		display: flex;
		justify-content: center;
		gap: 1.25rem;
		margin-bottom: 1rem;
	}

	.footer-social a {
		color: var(--color-text-muted);
		transition: color 0.2s, transform 0.2s;
	}

	.footer-social a:hover {
		color: var(--color-accent);
		transform: scale(1.15);
	}

	.footer-controls {
		display: flex;
		justify-content: center;
		gap: 1rem;
	}

	@media (max-width: 550px) {
		.navbar {
			padding: 0.5rem 1rem;
			gap: 0;
		}

		.navbar--scrolled {
			padding: 0.5rem 1rem;
		}

		.navbar-brand {
			margin: 0 0.5rem;
		}

		.navbar-brand :global(img) {
			width: 80px;
			height: auto;
		}

		.navbar-links {
			align-items: center;
			gap: 0.75rem;
		}

		.navbar-links a {
			font-size: 0.6rem;
			text-align: center;
		}

		main {
			padding: 1rem;
		}

		footer {
			margin-top: 2rem;
			padding: 1.5rem 1rem;
		}
	}
</style>
