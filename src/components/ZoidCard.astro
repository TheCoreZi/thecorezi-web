---
import type { DatePrecision, Zoid } from '../types/zoid';

interface Props {
	zoid: Zoid;
}

const { zoid } = Astro.props;

function formatDate(date: number | null, precision: DatePrecision): string {
	if (!date) return 'TBA';
	const options: Intl.DateTimeFormatOptions = {
		DAY: { year: 'numeric', month: 'long', day: 'numeric' },
		MONTH: { year: 'numeric', month: 'long' },
		YEAR: { year: 'numeric' },
	}[precision] satisfies Intl.DateTimeFormatOptions;
	const formatted = new Date(date).toLocaleDateString('es', { ...options, timeZone: 'UTC' });
	return formatted.replace(/\b[a-záéíóúñ]+\b/g, (word) =>
		['de'].includes(word) ? word : word.charAt(0).toUpperCase() + word.slice(1)
	);
}
---

<details class="zoid-card" data-zoid-card>
	<summary class="zoid-summary">
		{zoid.image_url && (
			<img src={zoid.image_url} alt={zoid.name} class="zoid-image" />
		)}
		<div class="zoid-info">
			{zoid.model_code && <span class="zoid-code">{zoid.model_code}</span>}
			<h3 class="zoid-name">{zoid.name}</h3>
			<div class="zoid-bottom">
				<div class="zoid-dates">
					<span class="date-label">Preventa: <strong>{formatDate(zoid.reserve_date, zoid.reserve_date_precision)}</strong></span>
					<span class="date-label">Lanzamiento: <strong>{formatDate(zoid.launch_date, zoid.launch_date_precission)}</strong></span>
				</div>
				{zoid.retail_price && zoid.currency && (
					<p class="zoid-price">{zoid.retail_price.toLocaleString('en', { style: 'currency', currency: zoid.currency })}</p>
				)}
			</div>
		</div>
	</summary>

	<div class="zoid-detail">
			<p class="zoid-meta">{zoid.brand} &mdash; {zoid.line}</p>

			{zoid.retail_price && zoid.currency && (
				<p class="zoid-detail-price">{zoid.retail_price.toLocaleString('en', { style: 'currency', currency: zoid.currency })}</p>
			)}

			<div class="zoid-detail-dates">
				<span class="date-label">Preventa: <strong>{formatDate(zoid.reserve_date, zoid.reserve_date_precision)}</strong></span>
				<span class="date-label">Lanzamiento: <strong>{formatDate(zoid.launch_date, zoid.launch_date_precission)}</strong></span>
			</div>

			{zoid.description && (
				<p class="zoid-description">{zoid.description}</p>
			)}

			{zoid.features && zoid.features.length > 0 && (
				<div class="zoid-features-section">
					<h4>Características</h4>
					<ul class="zoid-features">
						{zoid.features.map((feature: string) => (
							<li>{feature}</li>
						))}
					</ul>
				</div>
			)}

			{zoid.official_link && (
				<a href={zoid.official_link} target="_blank" rel="noopener noreferrer" class="official-link">Ver página oficial</a>
			)}
	</div>
</details>

<style>
	.zoid-card {
		background-color: var(--color-surface);
		border: 1px solid var(--color-primary);
		border-radius: 8px;
		overflow: hidden;
		transition: border-color 0.2s;
	}

	.zoid-card:hover,
	.zoid-card[open] {
		border-color: var(--color-accent);
	}


	.zoid-summary {
		cursor: pointer;
		list-style: none;
		display: block;
	}

	/* Hide the default details arrow across browsers */
	.zoid-summary::-webkit-details-marker,
	.zoid-summary::marker {
		display: none;
		content: '';
	}

	.zoid-image {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
	}

	.zoid-info {
		padding: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.zoid-code {
		font-family: 'Courier New', monospace;
		font-size: 0.8rem;
		color: var(--color-text-muted);
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.zoid-name {
		font-family: 'Impact', 'Arial Narrow', sans-serif;
		font-size: 1.6rem;
		color: var(--color-text);
		text-transform: uppercase;
		letter-spacing: 0.03em;
		margin-bottom: 0.5rem;
	}

	.zoid-bottom {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: 1rem;
	}

	.zoid-price {
		color: var(--color-accent);
		font-size: 1.1rem;
		font-weight: 700;
		white-space: nowrap;
	}

	.zoid-dates {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.date-label {
		color: var(--color-text-muted);
		font-size: 0.85rem;
	}

	.date-label strong {
		color: var(--color-accent);
	}

	.zoid-detail {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 1.25rem;
		border-top: 1px solid var(--color-primary);
	}

	.zoid-detail-dates {
		display: flex;
		gap: 2rem;
		flex-wrap: wrap;
	}

	.zoid-detail-price {
		color: var(--color-accent);
		font-size: 1.5rem;
		font-weight: 700;
	}

	.zoid-meta {
		color: var(--color-text-muted);
		font-size: 0.95rem;
	}

	.zoid-description {
		color: var(--color-text);
		font-size: 1.05rem;
		line-height: 1.7;
	}

	.zoid-features-section h4 {
		color: var(--color-text);
		font-size: 1.1rem;
		margin-bottom: 0.5rem;
	}

	.zoid-features {
		color: var(--color-text-muted);
		font-size: 0.95rem;
		line-height: 1.8;
		padding-left: 1.25rem;
		list-style: disc;
	}

	.official-link {
		display: inline-block;
		background-color: var(--color-accent);
		color: var(--color-bg);
		font-size: 0.95rem;
		font-weight: 700;
		text-decoration: none;
		padding: 0.75rem 1.5rem;
		border-radius: 6px;
		border: 2px solid var(--color-accent);
		transition: background-color 0.2s, color 0.2s;
		align-self: flex-start;
	}

	.official-link:hover {
		background-color: transparent;
		color: var(--color-accent);
	}
</style>

<script>
	const DURATION = 350;
	const EASING = 'ease-in-out';

	function getWrapper(card: HTMLDetailsElement): HTMLElement {
		return card.parentElement ?? card;
	}

	function expandWrapper(wrapper: HTMLElement) {
		wrapper.style.gridColumn = '1 / -1';
		wrapper.style.order = '-1';
	}

	function resetWrapper(wrapper: HTMLElement) {
		wrapper.style.gridColumn = '';
		wrapper.style.order = '';
	}

	function collapseCard(card: HTMLDetailsElement) {
		const wrapper = getWrapper(card);
		const fromRect = wrapper.getBoundingClientRect();
		card.open = false;
		resetWrapper(wrapper);
		const toRect = wrapper.getBoundingClientRect();

		card.open = true;
		expandWrapper(wrapper);

		card.style.overflow = 'hidden';
		wrapper.animate(
			{
				width: [`${fromRect.width}px`, `${toRect.width}px`],
				height: [`${fromRect.height}px`, `${toRect.height}px`],
			},
			{ duration: DURATION, easing: EASING },
		).onfinish = () => {
			card.open = false;
			resetWrapper(wrapper);
			card.style.overflow = '';
		};
	}

	document.addEventListener('click', (e) => {
		const summary = (e.target as HTMLElement).closest('[data-zoid-card] > summary');
		if (!summary) return;

		const card = summary.parentElement as HTMLDetailsElement;
		if (card.open) {
			e.preventDefault();
			collapseCard(card);
			return;
		}

		document.querySelectorAll<HTMLDetailsElement>('[data-zoid-card][open]').forEach((other) => {
			if (other !== card) {
				other.open = false;
				resetWrapper(getWrapper(other));
			}
		});

		const wrapper = getWrapper(card);
		const fromRect = wrapper.getBoundingClientRect();
		e.preventDefault();
		card.open = true;
		expandWrapper(wrapper);
		const toRect = wrapper.getBoundingClientRect();

		card.style.overflow = 'hidden';
		wrapper.animate(
			{
				width: [`${fromRect.width}px`, `${toRect.width}px`],
				height: [`${fromRect.height}px`, `${toRect.height}px`],
			},
			{ duration: DURATION, easing: EASING },
		).onfinish = () => {
			card.style.overflow = '';
		};
	});
</script>
